from contas.conta import Conta

class ContaCorrente(Conta):
    def __init__(self, numero: int, cliente, limite: float = 500.0):
        super().__init__(numero, cliente)
        self.limite = limite

    def sacar(self, valor: float) -> bool:
        if valor > 0 and (self.saldo + self.limite) >= valor:
            self._atualizar_saldo(valor)
            self.historico.adicionar_transacao("Saque", valor)
            print(f"Saque de R$ {valor:.2f} realizado.")
            return True
        print("Saldo/Limite insuficiente ou valor inválido!") # Mensagem clara no terminal [cite: 59]
        return False